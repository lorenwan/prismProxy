### 消息类型

```go
// MessageType 消息类型
type MessageType string

const (
    // 流量相关
    MsgNewTraffic      MessageType = "new_traffic"
    MsgTrafficUpdate   MessageType = "traffic_update"
    MsgTrafficDelete   MessageType = "traffic_delete"
    MsgTrafficClear    MessageType = "traffic_clear"
    
    // 断点相关
    MsgBreakpointHit   MessageType = "breakpoint_hit"
    MsgBreakpointResolve MessageType = "breakpoint_resolve"
    
    // 规则相关
    MsgRuleUpdate      MessageType = "rule_update"
    
    // AI 相关
    MsgAIAnalysis      MessageType = "ai_analysis"
    MsgAIStreamChunk   MessageType = "ai_stream_chunk"
    
    // 系统相关
    MsgSystemStatus    MessageType = "system_status"
    MsgError           MessageType = "error"
)

// Message WebSocket 消息
type Message struct {
    Type    MessageType `json:"type"`
    Payload interface{} `json:"payload"`
    ID      string      `json:"id,omitempty"`
}
```

