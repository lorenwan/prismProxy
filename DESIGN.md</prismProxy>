// Breakpoint 断点
type Breakpoint struct {
    ID          string         `json:"id"`
    Enabled     bool           `json:"enabled"`
    Phase        Phase         `json:"phase"`        // request, response
    Match        RuleMatch     `json:"match"`         // 复用规则匹配
    Action       BreakAction   `json:"action"`
    HitCount     int           `json:"hit_count"`
    CreatedAt    time.Time     `json:"created_at"`
}

type Phase string

const (
    PhaseRequest  Phase = "request"
    PhaseResponse Phase = "response"
)

type BreakAction struct {
    Type         string        `json:"type"`          // pause, auto_modify, drop
    AutoModify   *ModifySpec   `json:"auto_modify,omitempty"`
}

// BreakpointSession 断点会话
type BreakpointSession struct {
    ID            string        `json:"id"`
    BreakpointID  string        `json:"breakpoint_id"`
    TransactionID int64         `json:"transaction_id"`
    Phase         Phase         `json:"phase"`
    Status        string        `json:"status"`       // paused, modified, released, dropped
    Original      *Transaction  `json:"original"`
    Modified      *Transaction  `json:"modified,omitempty"`
    CreatedAt     time.Time     `json:"created_at"`
    ResolvedAt    *time.Time    `json:"resolved_at,omitempty"`
}
```

### 断点工作流

```
1. 用户设置断点 (匹配条件 + 动作)
2. 请求到达 → 匹配断点
3. 创建断点会话 → 暂停请求
4. 通过 WebSocket 通知前端
5. 用户操作:
   a. 查看请求/响应详情
   b. 修改请求/响应
   c. 释放请求继续
   d. 丢弃请求
6. 执行相应动作
7. 记录断点会话结果
```

